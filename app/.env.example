# Trinity AGI Environment Configuration
# Copy this file to .env and fill in ALL values before running docker compose.
#
# IMPORTANT: Each secret MUST be a unique, randomly-generated value.
# Generate secrets with: openssl rand -hex 32
# Do NOT reuse the same value for multiple secrets.
# Do NOT use default/placeholder values like "admin", "root", "test", etc.
# Do NOT commit the .env file to version control.

# === OpenClaw Gateway ===
# Must be >= 16 characters. Used for gateway auth and terminal proxy.
OPENCLAW_GATEWAY_TOKEN=

# === Supabase ===
# JWT_SECRET must be >= 32 characters and DIFFERENT from OPENCLAW_GATEWAY_TOKEN.
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
# Must be >= 16 characters. Do NOT use "postgres".
SUPABASE_POSTGRES_PASSWORD=

# === Keycloak ===
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=

# === Superadmin ===
# User ID(s) allowed to have superadmin role (comma-separated)
SUPERADMIN_ALLOWLIST=
ENABLE_DEFAULT_SUPERADMIN=false
DEFAULT_SUPERADMIN_EMAIL=admin@trinity.work
DEFAULT_SUPERADMIN_PASSWORD=

# === CORS ===
# Comma-separated list of allowed origins (e.g., https://trinity.example.com)
ALLOWED_ORIGINS=http://localhost

# === Database ===
POSTGRES_USER=supabase_admin

# === Grafana ===
GRAFANA_PASSWORD=

# === Vault ===
VAULT_TOKEN=

# === Web Search (OpenClaw) ===
# Brave Search API key for web_search tool (get one at https://brave.com/search/api/)
# Alternative providers: set PERPLEXITY_API_KEY, OPENROUTER_API_KEY, or GEMINI_API_KEY instead
BRAVE_API_KEY=

# === OpenCode Copilot ===
# Zen provider API key for the dedicated copilot service
ZEN_API_KEY=
# Desired OpenCode model for copilot (service will only apply it if available)
COPILOT_DEFAULT_MODEL=moonshotai/kimi-k2.5

# === LightRAG Sidecar ===
# Internal bearer token used by trusted Trinity callers when talking to the LightRAG sidecar.
# Set this explicitly; do not expose the sidecar directly to end users.
LIGHTRAG_INTERNAL_TOKEN=
# Optional model configuration for the sidecar.
LIGHTRAG_LLM_MODEL=gpt-4o-mini
LIGHTRAG_LLM_API_KEY=
LIGHTRAG_LLM_BASE_URL=
LIGHTRAG_EMBEDDING_MODEL=text-embedding-3-large
LIGHTRAG_EMBEDDING_API_KEY=
LIGHTRAG_EMBEDDING_BASE_URL=
LIGHTRAG_EMBEDDING_DIM=3072
LIGHTRAG_EMBEDDING_MAX_TOKENS=8192
LIGHTRAG_DEFAULT_QUERY_MODE=hybrid
LIGHTRAG_ENABLE_RERANK=true
# Optional OpenAI-compatible credentials for LightRAG indexing/querying.
OPENAI_API_KEY=
OPENAI_BASE_URL=

# === Nano Banana 2 (POE) ===
# POE API key for nano-banana-2-poe skill (get one at https://poe.com/settings)
POE_API_KEY=

# === Tech News Digest ===
# GitHub token for higher API rate limits (optional, 60 req/hr without)
GITHUB_TOKEN=
# Twitter/X API bearer token for KOL monitoring (optional, reserved for future use)
X_BEARER_TOKEN=

# === YouTube Digest ===
# YouTube Data API v3 key (get one at https://console.cloud.google.com/)
YOUTUBE_API_KEY=

# === Polymarket Autopilot ===
# Discord webhook URL for posting daily paper trading summaries (optional)
# Create one at: Discord Server Settings > Integrations > Webhooks > New Webhook
DISCORD_WEBHOOK_URL=

# === URLs (Production) ===
# Override these when deploying behind a domain (default: http://localhost)
API_EXTERNAL_URL=http://localhost
SITE_URL=http://localhost

# === Authentik (Optional) ===
AUTHENTIK_ENABLED=false
AUTHENTIK_ISSUER_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SCOPES=openid profile email groups
AUTHENTIK_GROUPS_MAPPER_ENABLED=true
AUTHENTIK_DEFAULT_GROUP_VALUE=trinity_user

# === Container Registry (ghcr.io) ===
# Personal access token for pushing images to ghcr.io
GHCR_TOKEN=
