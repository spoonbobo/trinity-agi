# Trinity AGI Environment Configuration
# Copy this file to .env and fill in ALL values before running docker compose.
# Generate secrets with: openssl rand -hex 32

# === OpenClaw Gateway ===
OPENCLAW_GATEWAY_TOKEN=

# === Supabase ===
SUPABASE_JWT_SECRET=
SUPABASE_ANON_KEY=
SUPABASE_POSTGRES_PASSWORD=

# === Keycloak ===
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=

# === Superadmin ===
# User ID(s) allowed to have superadmin role (comma-separated)
SUPERADMIN_ALLOWLIST=
ENABLE_DEFAULT_SUPERADMIN=false
DEFAULT_SUPERADMIN_EMAIL=admin@trinity.local
DEFAULT_SUPERADMIN_PASSWORD=

# === CORS ===
# Comma-separated list of allowed origins (e.g., https://trinity.example.com)
ALLOWED_ORIGINS=http://localhost

# === Database ===
POSTGRES_USER=postgres

# === Grafana ===
GRAFANA_PASSWORD=

# === Vault ===
VAULT_TOKEN=

# === Web Search (OpenClaw) ===
# Brave Search API key for web_search tool (get one at https://brave.com/search/api/)
# Alternative providers: set PERPLEXITY_API_KEY, OPENROUTER_API_KEY, or GEMINI_API_KEY instead
BRAVE_API_KEY=

# === URLs (Production) ===
# Override these when deploying behind a domain (default: http://localhost)
API_EXTERNAL_URL=http://localhost
SITE_URL=http://localhost

# === Authentik (Optional) ===
AUTHENTIK_ENABLED=false
AUTHENTIK_ISSUER_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SCOPES=openid profile email groups
AUTHENTIK_GROUPS_MAPPER_ENABLED=true
AUTHENTIK_DEFAULT_GROUP_VALUE=trinity_user
