# Trinity AGI Environment Configuration
# Copy this file to .env and fill in the values

# === OpenClaw Gateway ===
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# === Supabase ===
# Generate JWT secret: openssl rand -hex 32
SUPABASE_JWT_SECRET=
# Generate anon key: openssl rand -hex 32 or use Supabase dashboard
SUPABASE_ANON_KEY=
SUPABASE_POSTGRES_PASSWORD=

# === Keycloak ===
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_SECRET=

# === Vault ===
# Vault token (set after running vault-init)
VAULT_TOKEN=

# === Superadmin ===
# User ID(s) allowed to have superadmin role (comma-separated)
SUPERADMIN_ALLOWLIST=
ENABLE_DEFAULT_SUPERADMIN=true

# === Grafana ===
GRAFANA_PASSWORD=admin123
GRAFANA_ROOT_URL=http://localhost:3000

# === JWT Configuration ===
JWT_EXPIRY_HOURS=24

# === Authentik (Optional) ===
AUTHENTIK_ENABLED=false
AUTHENTIK_ISSUER_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SCOPES=openid profile email groups
AUTHENTIK_GROUPS_MAPPER_ENABLED=true
AUTHENTIK_DEFAULT_GROUP_VALUE=trinity_user
