        {
          "rawSql": "SELECT\n  date_trunc('minute', created_at) AS time,\n  action,\n  count(*) AS value\nFROM rbac.audit_log\nWHERE action IN ('auth.login.success', 'auth.login.failed', 'auth.token.expired')\n  AND created_at >= $__timeFrom()\n  AND created_at <= $__timeTo()\nGROUP BY 1, 2\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "title": "Login Events",
      "type": "timeseries"
    },
